<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
  <Dialog id="updateDialog" title="Update Employee" type="Message">
    <content>
      <VBox class="sapUiSmallMargin">

        <Label text="EmpId" labelFor="updEmpId"/>
        <!-- If EmpId should not be changed, set editable="false" -->
        <Input id="updEmpId" value="{EmpId}" editable="false"/>

        <Label text="Name" labelFor="updName"/>
        <Input id="updName" value="{Name}" />

        <Label text="Salary" labelFor="updSalary"/>
        <Input id="updSalary" value="{Salary}"/>
        <!-- Salary kept as string per your requirement -->

        <Label text="Gender" labelFor="updGender"/>
        
<Select id="updGender"
        selectedKey="{ path: 'Gender', mode: 'OneWay' }"
        forceSelection="true"
        width="100%">
    <core:Item key="Male"   text="Male"/>
    <core:Item key="Female" text="Female"/>
    <core:Item key="Others" text="Others"/>
</Select>
        <Label text="Age" labelFor="updAge"/>
        <Input id="updAge"  type="Number" value="{Age}"/>


      </VBox>
    </content>

    <beginButton>
      <Button text="Update" type="Emphasized" press=".onConfirmUpdate"/>
    </beginButton>
    <endButton>
      <Button text="Cancel" press=".onCancelUpdate"/>
    </endButton>
  </Dialog>
</core:FragmentDefinition>