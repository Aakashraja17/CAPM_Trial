<mvc:View controllerName="com.capmlearn.uicapm.controller.View1"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m">
	<Page id="page" title="{i18n>title}">
		<subHeader>
			<OverflowToolbar>
				 <Button text="Create" type="Emphasized" press="onOpenCreateDialog" icon="sap-icon://add"/>
				<ToolbarSpacer />
				<Input id= "idFilterName" placeholder="Name" liveChange="onFilter" width="200px" ></Input>
				<Button icon="sap-icon://search" press="onFilter"/>
				<Button icon="sap-icon://sort" press="onSort"/>
			</OverflowToolbar>
		</subHeader>
		<Table id= "idEmpTable" 
		mode="SingleSelectMaster"
                items="{
                path: '/Employee',
                parameters: { $select : 'EmpId,Name,Salary,Gender' }
             }"
			 itemPress="onItemPress"

			 >
			<columns>
				<Column >
					<Text text="EmpId"></Text>
				</Column>
				<Column >
					<Text text="Name"></Text>
				</Column>
				<Column >
					<Text text="Gender"></Text>
				</Column>
				<Column >
					<Text text="Update"></Text>
				</Column>
				<Column >
					<Text text="Delete"></Text>
				</Column>
			</columns>
			<items>
			<ColumnListItem type="Active">
				<cells>
					<ObjectIdentifier title="{EmpId}"/>
					<Text text="{Name}"></Text>
					<Text text="{Gender}"></Text>
					<Button icon="sap-icon://edit" press=".onOpenUpdateDialog"/>
					<Button icon="sap-icon://delete" press="onDeleteRow"/>
				</cells>
			</ColumnListItem>
			</items>
		</Table>
	</Page>
</mvc:View>